generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Admin {
  id Int @id @default(autoincrement())

  name String

  email String @unique

  password String

  role String @default("admin")

  isActive Boolean @default(true)

  lastLogin DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@map("admins")
}

model VolunteerApplication {
  id Int @id @default(autoincrement())

  // Personal Information
  fullName String
  email    String
  phone    String

  dob DateTime?

  gender String?

  nationality String?

  occupation String?

  address String?

  // Emergency Contact
  emergencyName String?

  emergencyPhone String?

  // Volunteer Role
  position String?

  department Json @default("[]")

  duration String?

  arrangement String?

  startDate DateTime?

  supervisor String?

  // Agreements
  agreements Json @default("[]")

  mediaConsent Boolean @default(false)

  volunteerName String?

  signature String?

  declarationDate DateTime?

  // Admin
  status String @default("Pending")

  approvedBy String?

  approverPosition String?

  approverSignature String?

  approvalDate DateTime?

  // Timestamps
  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([email])
  @@map("volunteer_applications")
}

enum NewsletterStatus {
  ACTIVE
  UNSUBSCRIBED
}

model NewsletterSubscriber {
  id Int @id @default(autoincrement())

  fullName String?
  email    String  @unique

  status         NewsletterStatus @default(ACTIVE)
  subscribedAt   DateTime         @default(now())
  unsubscribedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, subscribedAt])
  @@map("newsletter_subscribers")
}

enum ContactSubmissionStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

model ContactSubmission {
  id Int @id @default(autoincrement())

  fullName String @db.VarChar(120)
  email    String @db.VarChar(254)
  subject  String @db.VarChar(160)
  message  String @db.Text

  status ContactSubmissionStatus @default(NEW)

  respondedAt DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([email])
  @@map("contact_submissions")
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

model Post {
  id Int @id @default(autoincrement())

  title   String @db.VarChar(200)
  slug    String @unique @db.VarChar(220)
  excerpt String @db.Text
  content String @db.LongText

  featuredImage    String? @db.VarChar(2048)
  featuredImageAlt String? @db.VarChar(255)

  status     PostStatus @default(DRAFT)
  isFeatured Boolean    @default(false)

  categoryId Int?
  category   PostCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  seoTitle       String? @db.VarChar(200)
  seoDescription String? @db.VarChar(320)

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([categoryId])
  @@index([publishedAt])
  @@map("posts")
}

model PostCategory {
  id Int @id @default(autoincrement())

  name        String  @db.VarChar(120)
  slug        String  @unique @db.VarChar(140)
  description String? @db.Text

  posts Post[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("post_categories")
}
