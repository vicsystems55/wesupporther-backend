generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id Int @id @default(autoincrement())

  name String

  email String @unique

  password String

  role String @default("admin")

  isActive Boolean @default(true)

  lastLogin DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@map("admins")
}
